{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/state", "dest": "/api/state.py" },
    { "src": "/api/vessel/([^/]+)", "dest": "/api/vessel.py?mmsi=$1" },
    { "src": "/api/vessel", "dest": "/api/vessel.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
